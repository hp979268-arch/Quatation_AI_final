{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Shreeji Ceramica Quotation AI frontend, PWA, desktop, and mobile shell",
  "homepage": ".",
  "main": "electron/main.js",
  "dependencies": {
    "@capacitor/android": "^7.6.0",
    "@capacitor/ios": "^7.6.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.13.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "build:app": "cmd /c \"set BUILD_PATH=build_app&& react-scripts build\"",
    "desktop:start": "electron electron/main.js",
    "desktop:dev": "set \"ELECTRON_START_URL=http://localhost:3000\" && electron electron/main.js",
    "mobile:sync": "npx cap sync",
    "mobile:open:android": "npx cap open android",
    "mobile:open:ios": "npx cap open ios",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.quotationai.app",
    "productName": "Shreeji Ceramica",
    "directories": {
      "output": "dist_client"
    },
    "files": [
      "build/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend_sidecar_internal",
        "to": "backend_sidecar"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "dir"
      ],
      "icon": null,
      "signAndEditExecutable": false
    },
    "nsis": {
      "artifactName": "Shreeji Ceramica Setup ${version}.${ext}",
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "uninstallDisplayName": "Shreeji Ceramica",
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Shreeji Ceramica",
      "runAfterFinish": true
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "asar": false,
    "compression": "store",
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "extends": null
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.1",
    "@capacitor/core": "^7.0.1",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
